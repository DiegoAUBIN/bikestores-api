<?xml version="1.0" encoding="UTF-8"?>
<phpdocumentor
    configVersion="3"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://www.phpdoc.org"
    xsi:schemaLocation="https://www.phpdoc.org https://raw.githubusercontent.com/phpDocumentor/phpDocumentor/master/data/xsd/phpdoc.xsd"
>
    <title>BikeStores API Documentation</title>

    <paths>
        <output>var/phpdoc</output>
        <cache>var/phpdoc-cache</cache>
    </paths>

    <version number="1.0.0">
        <api>
            <source dsn=".">
                <path>src</path>
            </source>

            <ignore>
                <path>vendor</path>
                <path>var</path>
                <path>tests</path>
            </ignore>
        </api>
    </version>
</phpdocumentor>
